# Database URL (PostgreSQL) - Use 'db' as host for Docker
# DATABASE_URL="postgresql://quituser:quitpass@db:5432/quitpetas?schema=public"

# Database Credentials (for Docker)
POSTGRES_USER=quituser
POSTGRES_PASSWORD=quitpass
POSTGRES_DB=quitpetas

# JWT Secret for Auth
JWT_SECRET="your_secret_key_here"

# OpenAI API Key for Coach IA
OPENAI_API_KEY="sk-..."

# VAPID Keys for Push Notifications
# Generate them with npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="B..."
VAPID_PRIVATE_KEY="..."

# Production Environment
# NODE_ENV="production"
PORT=3000
